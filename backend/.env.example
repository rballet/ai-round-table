# Backend Environment Variables
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama: use localhost when running the backend directly,
# or host.docker.internal when running via docker compose.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Seconds to wait for a single LLM call before timing out. Increase for
# large context windows or slow reasoning models (default: 120).
LLM_TIMEOUT_SECONDS=120

# DATABASE_URL is overridden by docker-compose.yml to use the volume path.
DATABASE_URL=sqlite+aiosqlite:///./ai_round_table.db

# Directory for per-session prompt debug logs. Leave empty to disable.
# docker-compose.yml sets this to /app/logs (mounted at ./logs on the host).
# For local dev: set to an absolute path, e.g. /tmp/art-logs or ./logs
LOG_DIR=
